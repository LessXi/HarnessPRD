# ============================================================================
# HarnessPRD 环境配置
# 复制此文件为 .env 并填入实际值。所有字段均有默认值，可直接运行。
# ============================================================================
# 约定：
#   - 注释掉的 key 表示使用其默认值，无需取消注释
#   - 未注释的 key 建议根据实际环境修改
# ===========================================================================


# ================================ 应用基础 ================================
APP_NAME=HarnessPRD
APP_VERSION=1.0.0
DEBUG=true


# ================================ 服务端 ================================
# uvicorn 启动地址
SERVER_HOST=0.0.0.0
SERVER_PORT=8000


# ================================ CORS 跨域 ================================
# 逗号分隔，允许的来源列表。多个来源用逗号隔开。
# 生产环境请替换为实际域名。
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173


# ================================ LLM 提供方 ================================
# 可选: openai / anthropic / deepseek
LLM_PROVIDER=openai

# --- OpenAI ---
# 至少配置 LLM_PROVIDER 对应的 API Key，否则程序启动会报错
OPENAI_API_KEY=
# 可选模型覆盖（不填则使用 provider 默认模型）
# OPENAI_MODEL=

# --- Anthropic ---
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=

# --- DeepSeek ---
DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=

# --- MiMo（OpenAI 兼容） ---
# MIMO_API_KEY=
# MIMO_MODEL=
# MIMO_BASE_URL=


# ================================ 文档生成 ================================
# Review→Rewrite 循环最大轮次（建议 1-5）
MAX_REVIEW_ROUNDS=3
# SSE 流超时阈值（秒），超过此时间无新 chunk 视为断连
SSE_TIMEOUT_SECONDS=60


# ================================ Session ================================
# 内存中最多保留的 session 数，超出后自动删除最旧的
MAX_SESSIONS=100
